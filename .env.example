# ================================================================
# Azure AD Configuration
# ================================================================
# This app uses TWO auth flows from ONE app registration:
#   Option A (provisioning): Delegated auth via browser login
#   Option B (connector):    Application auth via client secret
#
# Azure AD App Requirements:
#   Platform: Single-page application (SPA)
#   Redirect URI: http://localhost:5544
#
#   Delegated permissions (Option A):
#     - User.ReadWrite.All
#     - Directory.ReadWrite.All
#     - People.Read.All
#     - Organization.Read.All
#     - offline_access
#
#   Application permissions (Option B):
#     - ExternalConnection.ReadWrite.OwnedBy
#     - ExternalItem.ReadWrite.OwnedBy
#     - PeopleSettings.ReadWrite.All
#
#   Grant admin consent after adding all permissions.
# ================================================================

# Directory (tenant) ID — Azure Portal > Entra ID > Overview
AZURE_TENANT_ID=your-tenant-id-here

# Application (client) ID — Azure Portal > App Registrations > Your App
AZURE_CLIENT_ID=your-client-id-here

# Client secret — REQUIRED for Option B (Graph Connector)
# Azure Portal > App Registrations > Your App > Certificates & secrets
AZURE_CLIENT_SECRET=your-client-secret-here

# Domain suffix for user principal names
# Used to construct email from MailNickName in JSON input
USER_DOMAIN=yourdomain.onmicrosoft.com

# ================================================================
# License Configuration
# ================================================================
# JSON input: per-user Licenses array with display names (auto-resolved)
# CSV input or fallback: LICENSE_SKU_IDS below
#
# Run 'npm run list-licenses' to see available SKUs in your tenant
LICENSE_SKU_IDS=

# ================================================================
# Optional Settings
# ================================================================

# Auth server port (default: 5544)
AUTH_SERVER_PORT=5544

# Default usage location (ISO 3166-1 alpha-2, e.g. US, NO, GB)
# Can be overridden per user in CSV/JSON
DEFAULT_USAGE_LOCATION=US

# Protected accounts — NEVER modified or deleted
PROTECTED_EMAIL_PATTERNS=admin@*,administrator@*,root@*,systemadmin@*
PROTECTED_EMAILS=
CHECK_ADMIN_ROLES=true
